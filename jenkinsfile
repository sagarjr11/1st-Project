pipeline{ 
    agent any
    environment {
    // Pulls username and password from Jenkins credentials
    DOCKER_CREDS  = credentials('dockerhub-creds')
     }

    stages{
        stage('Git Clone') {
            steps{
                 git branch: 'main', url: 'https://github.com/sagarjr11/1st-Project.git'
                echo 'Cloning Git repository...'
            }
         }
        stage('build image using dockerfile') {
            steps {
                echo 'Building Docker image...'
                sh 'docker build -t my-app .'
                sh "docker tag my-app:latest ${DOCKER_CREDS_USR}/my_app:v1.${BUILD_NUMBER}"
             
             }
         }
        stage('Push image to Docker Hub') {
            steps {
                echo 'Pushing image to Docker Hub...'
                sh """
                   echo ${DOCKER_CREDS_PSW} | docker login \
                   -u ${DOCKER_CREDS_USR} \
                   --password-stdin
                   """               //echo mypassword | docker login -u sagar --password-stdin
                sh 'docker push $DOCKER_CREDS_USR/my_app:v1.$BUILD_NUMBER'
             }
         }
         stage('Deploy to Ec2 Machine ') {
            steps {
                sshagent(credentials: ['ec2-ssh-key']) {
                echo 'Deploying to Ec2 Machine...'
                sh """
                    ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} '

                        docker pull ${IMAGE_NAME}:latest

                        docker stop myapp || true
                        docker rm myapp || true

                        docker run -d \
                          --name myapp \
                          -p 3000:3000 \
                          ${IMAGE_NAME}:latest
                    '
                    """
             }
         }
         }
    }    
}   